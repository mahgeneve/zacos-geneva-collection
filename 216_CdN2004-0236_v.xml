                 <lb n="2"/>σεrαου
                 <lb n="3"/>μαγγανη
                 <lb n="4"/>γεργι
              </ab>
            </div>
                  <div type="textpart" subtype="face" n="rev" rend="linear" xml:lang="grc">
                      <ab>
                         <lb n="5"/>Εξευλα            
                         <lb n="6"/>rειασου
                         <lb n="7"/>φερθον
                         <lb n="8"/>τυπον
                         </ab>
                  </div>
