              </ab>
            </div>
                  <div type="textpart" subtype="face" n="rev" rend="linear" xml:lang="grc">
                      <lg type="metrical" met="dodecasyllable" ana="nom">
                         <l n="1">
                            <lb n="1"/><expan><abbr>Ἰω</abbr><ex>άννης</ex></expan> 
