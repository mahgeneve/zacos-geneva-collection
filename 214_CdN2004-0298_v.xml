                      <ab>
                         <lb n="0"/>     
                         <lb n="1"/>σφραγι̣ς̣                
                         <lb n="2"/>σεrαης̣ 
                         <lb n="3"/>κοσ̣ 
                         <lb n="4"/>ευδοκια̣.
                         <lb n="0"/>  
                         </ab>
